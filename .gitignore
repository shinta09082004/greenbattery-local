# GIS large data files (too large for GitHub)
data/gis_raw/
data/*.zip

# Processed GIS data (regeneratable from gis_raw, some files >100MB)
data/processed/

# Cache files (regeneratable)
cache/

# Database files (environment-specific)
data/*.db
*.db
*.sqlite
*.sqlite3

# Regeneratable data
data/candidates.json

# Logs and local runtime files
conversation_log.md
startup_log.txt
logs/

# Local planning docs
plans/

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/

# Environment
.env
*.env

# Google Drive OAuth token (generated by upload script)
.gdrive_token.json
credentials.json

# Claude Code local settings (may contain tokens)
.claude/settings.local.json

# Session cookies
cookies.txt

# Presentation files
scripts/slides_anshin.html
scripts/slides_anshin.pptx
*.pptx

# Screenshots
*.png

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
logs/
